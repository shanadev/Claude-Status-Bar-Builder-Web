<Window x:Class="StatusBar.Builder.IconBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Icon browser — click an icon to use it" Width="680" Height="580"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <DockPanel Margin="8">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <ComboBox x:Name="SetCombo" DockPanel.Dock="Right" Width="190" FontSize="11"
                      Margin="6,0,0,0" SelectionChanged="Filter_Changed"/>
            <TextBox x:Name="SearchBox" FontSize="13" VerticalContentAlignment="Center"
                     TextChanged="Search_Changed"
                     ToolTip="Search by name or keyword — try 'dino', 'branch', 'coffee', 'rocket'"/>
        </DockPanel>
        <TextBlock x:Name="CountText" DockPanel.Dock="Bottom" FontSize="10" Foreground="#666666" Margin="0,6,0,0"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="ResultsPanel"/>
        </ScrollViewer>
    </DockPanel>
</Window>
