@page "/"
@inject NavigationManager Nav
@inject BuilderState State

<PageTitle>Hack the Claude Status Bar</PageTitle>

<section class="hero scanlines">
    <div class="horizon"><div class="plane"></div><div class="glowline"></div><div class="fade"></div></div>
    <img class="heromark" src="brand/logo.svg" alt="" />
    <h1 class="glitch" data-text="HACK THE CLAUDE STATUS BAR">Hack the <i>Claude</i> Status Bar</h1>
    <p class="tagline">A visual builder for Claude Code status lines, running entirely in your browser.
        Drag elements onto the canvas, style every segment, watch a real terminal render it live &#8212;
        then jack out with an installer for your OS. Your status bar never leaves the URL.</p>
    <div class="cta">
        <a class="btn go" href="build">Jack in</a>
        <a class="btn ghost" href="https://github.com/shanadev/Claude-Status-Bar-Builder-Web" target="_blank" rel="noopener">View source</a>
    </div>
    <div class="facts">
        <span><b>36</b> elements</span>
        <span><b>truecolor</b> ansi</span>
        <span>the whole bar fits <b>in the link</b></span>
        <span><b>GPL-3.0</b> free software</span>
    </div>
</section>

@code {
    protected override async Task OnInitializedAsync()
    {
        // A shared theme link should land in the builder with the theme loaded, not on the hero.
        await State.InitializeAsync(Nav);
        if (State.RemixedFromLink) Nav.NavigateTo("build");
    }
}
