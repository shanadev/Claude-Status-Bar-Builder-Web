@page "/"
@inject IJSRuntime JS

<PageTitle>Hack the Claude Status Bar</PageTitle>

<main class="stage">
    <h1>HACK THE CLAUDE STATUS BAR</h1>
    <p class="tag">Visual status line builder for Claude Code &mdash; running fully in your browser.</p>
    <div id="term"></div>
</main>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var theme = DefaultTheme.Create();
        var ctx = new SampleData().Build();
        var text = string.Join("\n", Composer.Compose(theme, ctx));
        var bg = Ansi.ToHex(theme.Background) ?? "#101014";
        await JS.InvokeVoidAsync("renderStatus", text, theme.FontFamily, bg);
    }
}
