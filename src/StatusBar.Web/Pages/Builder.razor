@page "/build"
@inject NavigationManager Nav
@inject BuilderState State
@implements IDisposable

<PageTitle>Build — Hack the Claude Status Bar</PageTitle>

<div class="workspace">
    <aside class="ws-palette">
        <ElementPalette />
    </aside>

    <main class="ws-main">
        @if (State.RemixedFromLink)
        {
            <span class="remixchip">&#9670; loaded from a shared link &#8212; this copy is yours to edit
                <button type="button" title="dismiss" @onclick="() => State.DismissRemix()">&#215;</button>
            </span>
        }
        <SegmentCanvas />
        <PreviewTerminal />
    </main>

    <aside class="ws-style">
        <StylePanel OnBrowseIcon="OpenIconBrowser" />
    </aside>
</div>

<IconBrowser @ref="_iconBrowser" />

@code {
    IconBrowser? _iconBrowser;

    protected override Task OnInitializedAsync() => State.InitializeAsync(Nav);

    protected override void OnInitialized() => State.Changed += StateHasChanged;

    Task OpenIconBrowser() => _iconBrowser?.OpenAsync() ?? Task.CompletedTask;

    public void Dispose() => State.Changed -= StateHasChanged;
}
