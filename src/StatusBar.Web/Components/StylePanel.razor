@* Hack the Claude Status Bar — style panel: right-rail inspector. Everything writes straight
   into the theme and re-renders the terminal — no apply button, ever.
   Copyright (C) 2026 Stephen Shanafelt
   SPDX-License-Identifier: GPL-3.0-only *@
@inject BuilderState State
@implements IDisposable

<div class="panel">
@* Breadcrumb = where-am-I + one-click jump to any level. "status bar" is always
   reachable — that's the global settings panel (was only findable by deselecting). *@
<div class="panel-head crumbs">
    <span class="crumbtrail">
        <button type="button" class="crumb @(State.SelectedRow is null ? "on" : null)"
                title="status bar settings — name &amp; terminal background"
                @onclick="() => State.SelectNone()">status bar</button>
        @if (State.SelectedRow is Row bcRow)
        {
            <span class="csep">&#9656;</span>
            <button type="button" class="crumb @(State.Selected is null ? "on" : null)"
                    title="row settings — separators, end caps, position"
                    @onclick="() => State.SelectRow(bcRow)">row @(State.Theme.Rows.IndexOf(bcRow) + 1)</button>
            @if (State.Selected is Segment bcSeg)
            {
                <span class="csep">&#9656;</span>
                <span class="crumb on">@ElementRegistry.Get(bcSeg.Element).Name</span>
            }
        }
    </span>
    <span class="t-micro" title="the Escape key steps selection back out one level at a time">esc backs out</span>
</div>
@if (State.Selected is Segment seg && State.SelectedRow is Row row)
{
    var def = ElementRegistry.Get(seg.Element);

    @if (seg.Element == ElementKind.Spacer)
    {
        <div class="sect">
            <div class="s-lab"><span>spacer width</span></div>
            <div class="selrow">
                <span class="k">width</span>
                <input type="text" value="@(seg.Text ?? "flex")" spellcheck="false"
                       @onchange="e => { seg.Text = e.Value?.ToString(); State.Notify(); }" />
            </div>
            <p class="t-small" style="margin-top:8px;">a number of spaces, or <b>flex</b> to push
            everything after it to the right edge of the terminal</p>
        </div>
    }
    else
    {
        @if (seg.Element == ElementKind.Text)
        {
            <div class="sect">
                <div class="s-lab"><span>text</span></div>
                <div class="selrow">
                    <input type="text" class="wide" value="@(seg.Text ?? "")" spellcheck="false"
                           @onchange="e => { seg.Text = e.Value?.ToString(); State.Notify(); }" />
                </div>
            </div>
        }

        <div class="sect">
            <div class="s-lab"><span>colors</span>
                <button type="button" class="reset" title="reset colors"
                        @onclick="() => { seg.Fg = seg.Bg = seg.IconFg = seg.LabelFg = seg.ValueFg = null; State.Notify(); }">&#8634;</button>
            </div>
            <div class="segctl">
                @foreach (var part in Enum.GetValues<Part>())
                {
                    var localPart = part;
                    <button type="button" class="@(_part == localPart ? "on" : null)"
                            @onclick="() => _part = localPart">@localPart.ToString().ToLowerInvariant()</button>
                }
            </div>
            @if (_part == Part.All)
            {
                <ColorField Label="fg" Value="@seg.Fg" ValueChanged="v => { seg.Fg = v; State.Notify(); }" />
                <ColorField Label="bg" Value="@seg.Bg" ValueChanged="v => { seg.Bg = v; State.Notify(); }" />
            }
            else
            {
                <ColorField Label="fg" Value="@PartFg(seg)" ValueChanged="v => { SetPartFg(seg, v); State.Notify(); }" />
                <p class="t-small">overrides the segment fg for the @_part.ToString().ToLowerInvariant() only</p>
            }
        </div>

        <div class="sect">
            <div class="s-lab"><span>text style</span></div>
            <div class="attrs">
                <button type="button" class="attr @(seg.Bold ? "on" : null)" style="font-weight:700"
                        @onclick="() => { seg.Bold = !seg.Bold; State.Notify(); }">B</button>
                <button type="button" class="attr @(seg.Dim ? "on" : null)" style="opacity:.7"
                        @onclick="() => { seg.Dim = !seg.Dim; State.Notify(); }">D</button>
                <button type="button" class="attr @(seg.Italic ? "on" : null)" style="font-style:italic"
                        @onclick="() => { seg.Italic = !seg.Italic; State.Notify(); }">I</button>
                <button type="button" class="attr @(seg.Underline ? "on" : null)" style="text-decoration:underline"
                        @onclick="() => { seg.Underline = !seg.Underline; State.Notify(); }">U</button>
            </div>
        </div>

        <div class="sect">
            <div class="s-lab"><span>icon</span>
                <button type="button" class="reset" title="reset to element default"
                        @onclick="() => { seg.Icon = null; State.Notify(); }">&#8634;</button>
            </div>
            <div class="iconrow">
                <span class="icochip">@(EffectiveIcon(seg, def) is { Length: > 0 } ic ? ic : "—")</span>
                <span class="iconname">@(seg.Icon is null ? "element default" : seg.Icon.Length == 0 ? "hidden" : "custom")</span>
                <button type="button" class="browse" @onclick="OnBrowseIcon">Browse</button>
            </div>
            <div class="selrow" style="margin-top:8px; @(seg.Icon == "" ? "margin-bottom:0;" : null)">
                <span class="k">show icon</span>
                <button type="button" class="toggle @(seg.Icon != "" ? "on" : null)"
                        @onclick="() => ToggleIconVisible(seg)">
                    <span class="tk"></span>@(seg.Icon != "" ? "shown" : "hidden")
                </button>
            </div>
            @if (seg.Icon != "" && EffectiveIcon(seg, def).Length > 0)
            {
                <div class="selrow" style="margin-bottom:0;">
                    <span class="k">space after</span>
                    <button type="button" class="toggle @(seg.IconSpace ? "on" : null)"
                            title="wide icons overhang their cell — an extra space keeps the text clear"
                            @onclick="() => { seg.IconSpace = !seg.IconSpace; State.Notify(); }">
                        <span class="tk"></span>@(seg.IconSpace ? "extra space" : "off")
                    </button>
                </div>
            }
        </div>

        <div class="sect">
            <div class="s-lab"><span>label</span>
                <button type="button" class="reset" title="reset to element default"
                        @onclick="() => { seg.Label = null; State.Notify(); }">&#8634;</button>
            </div>
            <div class="selrow">
                <span class="k">show label</span>
                <button type="button" class="toggle @(seg.Label != "" ? "on" : null)"
                        @onclick="() => ToggleLabelVisible(seg)">
                    <span class="tk"></span>@(seg.Label != "" ? "shown" : "hidden")
                </button>
            </div>
            @if (seg.Label != "")
            {
                <div class="selrow" style="margin-bottom:0;">
                    <span class="k">text</span>
                    <input type="text" value="@(seg.Label ?? "")" placeholder="@(def.DefaultLabel.Length > 0 ? def.DefaultLabel : "element default")"
                           spellcheck="false"
                           @onchange="e => { var v = e.Value?.ToString(); seg.Label = string.IsNullOrEmpty(v) ? null : v; State.Notify(); }" />
                </div>
            }
        </div>

        @if (def.Formats is not null || def.Options is not null)
        {
            <div class="sect">
                <div class="s-lab"><span>format</span></div>
                @if (def.Formats is not null)
                {
                    <div class="selrow">
                        <span class="k">value</span>
                        <select value="@(seg.Format ?? def.Formats[0].Key)"
                                @onchange="e => { var v = e.Value?.ToString(); seg.Format = v == def.Formats[0].Key ? null : v; State.Notify(); }">
                            @foreach (var (key, display) in def.Formats)
                            {
                                <option value="@key">@display</option>
                            }
                        </select>
                    </div>
                }
                @if (def.Options is not null)
                {
                    <div class="selrow">
                        <span class="k">extra</span>
                        <select value="@(seg.Option ?? def.Options[0].Key)"
                                @onchange="e => { var v = e.Value?.ToString(); seg.Option = v == def.Options[0].Key ? null : v; State.Notify(); }">
                            @foreach (var (key, display) in def.Options)
                            {
                                <option value="@key">@display</option>
                            }
                        </select>
                    </div>
                }
            </div>
        }

        @if (def.SupportsBar)
        {
            <div class="sect">
                <div class="s-lab"><span>progress bar</span></div>
                <div class="selrow">
                    <span class="k">bar</span>
                    <button type="button" class="toggle @(seg.Bar is not null ? "on" : null)"
                            @onclick="() => { seg.Bar = seg.Bar is null ? new BarOptions() : null; State.Notify(); }">
                        <span class="tk"></span>@(seg.Bar is not null ? "on" : "off")
                    </button>
                </div>
                @if (seg.Bar is BarOptions bar)
                {
                    <div class="selrow">
                        <span class="k">text fg</span>
                        <button type="button" class="toggle @(bar.MatchFg ? "on" : null)"
                                title="icon, label, and value text take the fill tip's current color &#8212; follows thresholds, zones, and gradients"
                                @onclick="() => { bar.MatchFg = !bar.MatchFg; State.Notify(); }">
                            <span class="tk"></span>match current bar color
                        </button>
                    </div>
                    <div class="selrow">
                        <span class="k">width</span>
                        <input type="number" min="2" max="60" value="@bar.Width"
                               @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var n)) bar.Width = Math.Clamp(n, 2, 60); State.Notify(); }" />
                    </div>
                    <div class="selrow">
                        <span class="k">smooth</span>
                        <button type="button" class="toggle @(bar.Smooth ? "on" : null)"
                                @onclick="() => { bar.Smooth = !bar.Smooth; State.Notify(); }">
                            <span class="tk"></span>&#8539;-block fill
                        </button>
                    </div>
                    <div class="selrow">
                        <span class="k">chars</span>
                        <input type="text" style="max-width:44px" maxlength="2" value="@bar.FilledChar" title="filled char"
                               @onchange="e => { var v = e.Value?.ToString(); if (!string.IsNullOrEmpty(v)) bar.FilledChar = v; State.Notify(); }" />
                        <input type="text" style="max-width:44px" maxlength="2" value="@bar.EmptyChar" title="empty char"
                               @onchange="e => { var v = e.Value?.ToString(); if (!string.IsNullOrEmpty(v)) bar.EmptyChar = v; State.Notify(); }" />
                    </div>
                    <div class="selrow">
                        <span class="k">brackets</span>
                        <input type="text" style="max-width:56px" maxlength="2" placeholder="[]" value="@(bar.Brackets ?? "")"
                               @onchange="e => { var v = e.Value?.ToString(); bar.Brackets = string.IsNullOrEmpty(v) ? null : v; State.Notify(); }" />
                    </div>
                    <ColorField Label="fill" Value="@bar.FilledFg" ValueChanged="v => { bar.FilledFg = v; State.Notify(); }" />
                    <ColorField Label="empty" Value="@bar.EmptyFg" ValueChanged="v => { bar.EmptyFg = v; State.Notify(); }" />
                    @if (bar.Stops is not { Count: > 0 })
                    {
                        <ColorField Label="grad a" Value="@bar.GradientFrom" ValueChanged="v => { bar.GradientFrom = v; State.Notify(); }" />
                        <ColorField Label="grad b" Value="@bar.GradientTo" ValueChanged="v => { bar.GradientTo = v; State.Notify(); }" />
                    }
                    <div class="s-lab"><span>color zones</span></div>
                    <div class="zonechips">
                        <button type="button" class="zchip" title="3 zones: green to 60%, amber to 85%, red to 100%"
                                style="background:linear-gradient(90deg,#9ece6a 0 60%,#e0af68 60% 85%,#f7768e 85% 100%)"
                                @onclick="() => ApplyZonePreset(bar, PresetGreenAmberRed)">grn&#183;amb&#183;red</button>
                        <button type="button" class="zchip" title="6 rainbow zones"
                                style="background:linear-gradient(90deg,#f7768e,#ff9e64,#e0af68,#9ece6a,#7aa2f7,#bb9af7)"
                                @onclick="() => ApplyZonePreset(bar, PresetRainbow)">rainbow</button>
                    </div>
                    @if (bar.Stops is { } zstops)
                    {
                        @foreach (var zs in zstops)
                        {
                            var z = zs;
                            <div class="threshrow">
                                <span class="t-small">up to</span>
                                <input type="number" min="1" max="100" value="@z.UpTo"
                                       @onchange="e => { if (double.TryParse(e.Value?.ToString(), out var d)) z.UpTo = Math.Clamp(d, 1, 100); CommitZoneOrder(bar); }" />
                                <span class="t-small">%</span>
                                <button type="button" class="x" title="remove zone"
                                        @onclick="() => { zstops.Remove(z); if (zstops.Count == 0) bar.Stops = null; State.Notify(); }">&#215;</button>
                            </div>
                            <ColorField Label="from" Value="@z.From" ValueChanged="v => { z.From = v; State.Notify(); }" />
                            <ColorField Label="to" Value="@z.To" ValueChanged="v => { z.To = v; State.Notify(); }" />
                        }
                    }
                    <button type="button" class="addlink" @onclick="() => AddZone(bar)">+ add zone</button>
                    <div class="selrow">
                        <span class="k">track</span>
                        <button type="button" class="toggle @(bar.TintTrack ? "on" : null)"
                                @onclick="() => { bar.TintTrack = !bar.TintTrack; State.Notify(); }">
                            <span class="tk"></span>tint with zone color
                        </button>
                    </div>
                }
            </div>
        }

        @if (def.SupportsThresholds)
        {
            <div class="sect">
                <div class="s-lab"><span>thresholds</span></div>
                @foreach (var rule in seg.Thresholds)
                {
                    var localRule = rule;
                    <div class="threshrow">
                        <span class="t-small">&#8805;</span>
                        <input type="number" min="0" max="100" value="@localRule.AtOrAbove"
                               @onchange="e => { if (double.TryParse(e.Value?.ToString(), out var d)) localRule.AtOrAbove = d; State.Notify(); }" />
                        <span class="t-small">%</span>
                        <button type="button" class="x" title="remove stop"
                                @onclick="() => { seg.Thresholds.Remove(localRule); State.Notify(); }">&#215;</button>
                    </div>
                    <ColorField Label="fg" Value="@localRule.Fg" ValueChanged="v => { localRule.Fg = v; State.Notify(); }" />
                    <ColorField Label="bg" Value="@localRule.Bg" ValueChanged="v => { localRule.Bg = v; State.Notify(); }" />
                }
                <button type="button" class="addlink" @onclick="() => AddStop(seg)">+ add stop</button>
            </div>
        }

        <div class="sect">
            <div class="s-lab"><span>section</span></div>
            <div class="selrow">
                <span class="k">end caps</span>
                <select value="@(seg.SectionCaps?.ToString() ?? "row")"
                        @onchange="e => SetSectionCaps(seg, e.Value?.ToString())">
                    <option value="row">row default</option>
                    @foreach (var c in Enum.GetValues<CapStyle>())
                    {
                        <option value="@c">@c.ToString().ToLowerInvariant()</option>
                    }
                </select>
            </div>
            <p class="t-small">a section is a run of chips between spacers &#8212; the first chip
            in the section that sets a cap style restyles the whole section's capsule</p>
        </div>

        <div class="sect">
            <button type="button" class="toggle @(seg.HideWhenMissing ? "on" : null)"
                    @onclick="() => { seg.HideWhenMissing = !seg.HideWhenMissing; State.Notify(); }">
                <span class="tk"></span>hide when zero / absent
            </button>
        </div>
    }
}
else if (State.SelectedRow is Row selRow)
{
    int rowNum = State.Theme.Rows.IndexOf(selRow) + 1;

    <div class="sect">
        <div class="s-lab"><span>separators</span></div>
        <div class="selrow">
            <span class="k">style</span>
            <select value="@selRow.Separator"
                    @onchange="e => { selRow.Separator = Enum.Parse<SeparatorStyle>(e.Value!.ToString()!); State.Notify(); }">
                @foreach (var s in Enum.GetValues<SeparatorStyle>())
                {
                    <option value="@s">@SepName(s)</option>
                }
            </select>
        </div>
        <div class="selrow">
            <span class="k">end caps</span>
            <select value="@selRow.Caps"
                    @onchange="e => { selRow.Caps = Enum.Parse<CapStyle>(e.Value!.ToString()!); State.Notify(); }">
                @foreach (var c in Enum.GetValues<CapStyle>())
                {
                    <option value="@c">@c.ToString().ToLowerInvariant()</option>
                }
            </select>
        </div>
        @if (selRow.Separator is SeparatorStyle.Pipe or SeparatorStyle.Dot or SeparatorStyle.ChevronLine)
        {
            <ColorField Label="sep" Value="@selRow.SeparatorFg" ValueChanged="v => { selRow.SeparatorFg = v; State.Notify(); }" />
        }
    </div>

    <div class="sect">
        <div class="s-lab"><span>arrange</span></div>
        <div class="selrow">
            <span class="k">move row</span>
            <span class="rowmove">
                <button type="button" class="attr" title="move this row up" disabled="@(rowNum == 1)"
                        @onclick="() => State.MoveRow(selRow, -1)">&#9650;</button>
                <button type="button" class="attr" title="move this row down"
                        disabled="@(rowNum == State.Theme.Rows.Count)"
                        @onclick="() => State.MoveRow(selRow, +1)">&#9660;</button>
            </span>
        </div>
    </div>

    <div class="sect">
        <p class="t-small">palette clicks and drops add elements to this row &#183; a row with no
        elements renders as a blank line</p>
    </div>
}
else
{
    <div class="sect">
        <div class="s-lab"><span>status bar name</span></div>
        <div class="selrow">
            <span class="k">name</span>
            <input type="text" id="theme-name" value="@State.Theme.Name" spellcheck="false"
                   @onchange="SetThemeName" />
        </div>
        <p class="t-small" style="margin-top:8px;">names the whole bar &#8212; it travels inside the
        share link and theme.json, and is how your bar shows up if you submit it as a template</p>
    </div>

    <div class="sect">
        <div class="s-lab"><span>terminal</span></div>
        <ColorField Label="term bg" Value="@State.Theme.Background" AllowNone="false"
                    ValueChanged="SetThemeBackground" />
    </div>

    <div class="sect">
        <p class="t-small">click a segment chip to style it &#8212; colors, icon, label, format,
        bars, thresholds &#183; click a row label to set its separators &amp; caps</p>
    </div>
}
</div>

@code {
    enum Part { All, Icon, Label, Value }
    Part _part = Part.All;

    [Parameter] public EventCallback OnBrowseIcon { get; set; }

    protected override void OnInitialized() => State.Changed += StateHasChanged;
    public void Dispose() => State.Changed -= StateHasChanged;

    string? PartFg(Segment seg) => _part switch
    {
        Part.Icon => seg.IconFg,
        Part.Label => seg.LabelFg,
        Part.Value => seg.ValueFg,
        _ => seg.Fg,
    };

    void SetSectionCaps(Segment seg, string? v)
    {
        seg.SectionCaps = v is null or "row" ? null : Enum.Parse<CapStyle>(v);
        State.Notify();
    }

    void SetPartFg(Segment seg, string? v)
    {
        switch (_part)
        {
            case Part.Icon: seg.IconFg = v; break;
            case Part.Label: seg.LabelFg = v; break;
            case Part.Value: seg.ValueFg = v; break;
            default: seg.Fg = v; break;
        }
    }

    static string EffectiveIcon(Segment seg, ElementDef def) => seg.Icon ?? def.DefaultIcon;

    void ToggleIconVisible(Segment seg)
    {
        seg.Icon = seg.Icon == "" ? null : "";
        State.Notify();
    }

    void ToggleLabelVisible(Segment seg)
    {
        seg.Label = seg.Label == "" ? null : "";
        State.Notify();
    }

    void AddStop(Segment seg)
    {
        seg.Thresholds.Add(new ThresholdRule { AtOrAbove = 70, Fg = "#ffb300" });
        State.Notify();
    }

    static readonly (double UpTo, string From)[] PresetGreenAmberRed =
        { (60, "#9ece6a"), (85, "#e0af68"), (100, "#f7768e") };
    static readonly (double UpTo, string From)[] PresetRainbow =
        { (17, "#f7768e"), (33, "#ff9e64"), (50, "#e0af68"), (67, "#9ece6a"), (83, "#7aa2f7"), (100, "#bb9af7") };
    static readonly string[] ZoneAccents = { "#9ece6a", "#e0af68", "#f7768e", "#7aa2f7", "#bb9af7" };

    void ApplyZonePreset(BarOptions bar, (double UpTo, string From)[] preset)
    {
        bar.Stops = new(preset.Select(p => new BarStop { UpTo = p.UpTo, From = p.From }));
        bar.GradientFrom = bar.GradientTo = null;
        State.Notify();
    }

    void AddZone(BarOptions bar)
    {
        if (bar.Stops is not { } stops)
        {
            bar.Stops = stops = new();
            if (Ansi.IsSet(bar.GradientFrom) && Ansi.IsSet(bar.GradientTo))
            {
                // Migrate the legacy whole-bar gradient into its exact single-stop equivalent.
                stops.Add(new BarStop { UpTo = 100, From = bar.GradientFrom, To = bar.GradientTo });
                bar.GradientFrom = bar.GradientTo = null;
            }
            else
            {
                stops.Add(new BarStop { UpTo = 100, From = bar.FilledFg ?? ZoneAccents[0] });
            }
            State.Notify();
            return;
        }
        // The previous last zone gives up the top half of its range to the new one.
        if (stops.Count > 0 && stops[^1].UpTo >= 100)
        {
            double prev = stops.Count > 1 ? stops[^2].UpTo : 0;
            stops[^1].UpTo = Math.Round(prev + (100 - prev) / 2);
        }
        stops.Add(new BarStop { UpTo = 100, From = ZoneAccents[stops.Count % ZoneAccents.Length] });
        State.Notify();
    }

    // Keep the editor list in UpTo order (the renderer sorts anyway; the UI should match it).
    void CommitZoneOrder(BarOptions bar)
    {
        if (bar.Stops is { } stops)
        {
            var sorted = stops.OrderBy(s => s.UpTo).ToList();
            for (int i = 0; i < sorted.Count; i++)
            {
                int cur = stops.IndexOf(sorted[i]);
                if (cur != i) stops.Move(cur, i);
            }
        }
        State.Notify();
    }

    void SetThemeName(ChangeEventArgs e)
    {
        State.Theme.Name = e.Value?.ToString() ?? "";
        State.Notify();
    }

    void SetThemeBackground(string? v)
    {
        State.Theme.Background = v ?? "#101014";
        State.Notify();
    }

    static string SepName(SeparatorStyle s) => s switch
    {
        SeparatorStyle.ChevronLine => "chevron line ›",
        SeparatorStyle.Chevron => "chevron (solid)",
        SeparatorStyle.Round => "round (solid)",
        SeparatorStyle.Slant => "slant (solid)",
        SeparatorStyle.Backslant => "backslant (solid)",
        SeparatorStyle.Flame => "flame (solid)",
        SeparatorStyle.Blocks => "blocks (solid)",
        _ => s.ToString().ToLowerInvariant(),
    };
}
