# ${PORT} is substituted at container startup (Railway injects PORT; the
# Dockerfile defaults it to 80 for local runs).

server {
    listen ${PORT};
    listen [::]:${PORT};
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Blazor publish pre-compresses every asset; hand the .gz straight over.
    gzip_static on;
    # Runtime fallback for anything without a .gz sibling.
    gzip on;
    gzip_types application/javascript application/json application/wasm text/css font/ttf image/svg+xml;
    gzip_min_length 1024;

    # Everything under _framework/ is content-fingerprinted by the publish.
    location /_framework/ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        try_files $uri =404;
    }

    # index.html carries the importmap of current fingerprints — never cache.
    location = /index.html {
        add_header Cache-Control "no-cache";
    }

    # The templates gallery re-fetches this after every approval merge — a stale
    # browser cache would hide freshly approved bars.
    location = /templates.json {
        add_header Cache-Control "no-cache";
    }

    # The install scripts are fetched with `irm | iex` / `curl | bash`. Without
    # a text type + charset, Invoke-RestMethod can return byte[] (pwsh) or
    # mis-decode UTF-8 as Latin-1 (PS 5.1), so force text/plain; charset=utf-8.
    location ~ \.(ps1|sh)$ {
        types { }
        default_type text/plain;
        charset utf-8;
        try_files $uri =404;
    }

    # SPA fallback: /build, /export and share links resolve client-side.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
